# --- Database (Postgres/Neon) ---
# Get both values from Neon -> Project -> Connect:
# - DATABASE_URL: pooled connection string (used by the running app)
# - DIRECT_URL: direct/non-pooled connection string (used by Prisma Migrate)
DATABASE_URL="replace-with-neon-pooled-connection-string"
DIRECT_URL="replace-with-neon-direct-connection-string"

# --- Auth (NextAuth.js) ---
# Generate with: npx auth secret   (or openssl rand -base64 32)
AUTH_SECRET="replace-with-a-random-32-byte-secret"
# Base URL of the app, used for callback URLs. In production, set this to your
# Vercel deployment URL (e.g. https://tably.vercel.app).
NEXTAUTH_URL="http://localhost:3000"

# --- OpenAI (receipt parsing, Phase 1) ---
OPENAI_API_KEY="sk-replace-me"
OPENAI_VISION_MODEL="gpt-4o"

# --- Pusher (real-time claim sync, Phase 2) ---
PUSHER_APP_ID="replace-me"
PUSHER_KEY="replace-me"
PUSHER_SECRET="replace-me"
PUSHER_CLUSTER="us2"
NEXT_PUBLIC_PUSHER_KEY="replace-me"
NEXT_PUBLIC_PUSHER_CLUSTER="us2"
